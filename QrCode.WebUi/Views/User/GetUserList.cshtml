@model List<QrCode.Domain.AggregateModels.Users.ApplicationUser>
@using Microsoft.AspNetCore.Identity;
@using QrCode.Domain.AggregateModels.Users;
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "GetUserList";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">

<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
<script type="text/javascript">
    $(document).ready(function () {
        $('#navbarCollapse > div > a.nav-item.nav-link.active').removeClass('active');
        $("#navbarCollapse > div > a:nth-child(4)").addClass("active");
       
       
    });
    
</script>
<!-- Arama Formu -->

<title>User List- Torruna</title>
<div class="container-fluid  pt-3 pb-4" style="overflow-x: auto;">
    <div class="container ">
        
        <div class="control-group mb-2">
            <form asp-controller="User" asp-action="GetUserList" method="get" >
           
                    <h4 class="text-secondary mb-3">User List</h4>
                <div class="input-group" style="justify-content:center">
                        
                    <div class="form-outline" data-mdb-input-init>
                        <input type="search" class="form-control p-4" name="searchString" placeholder="Search..."  />
                   
                    </div>
                    <button class="btn btn-info" type="submit"> <i class="fas fa-search"></i></button>

                    
              
                </div>
            </form>
        </div>
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert" style="background:#28a745;color:#fff">
                <i class="far fa-check-circle"></i> <strong>@TempData["Success"]</strong>'s permission has been changed
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>           
        }       
        <table class="table table-stripped mb-5" style="text-align:center">
          <thead>
              <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Email Confirm</th>
                    <th>Action</th>
              </tr>             
          </thead>

            <tbody>
                @{
                    var say = 1;
                }
                @foreach (var user in Model)
                {
                <tr>
                    <th scope="row">@say</th>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>
                            @if (user.EmailConfirmed)
                            {
                                <span class="text-bold text-success">@user.EmailConfirmed</span>
                            }
                            else
                            {
                                <span class="text-bold text-danger">@user.EmailConfirmed</span>
                            }
                    </td>
                    <td>
                            @if (!await UserManager.IsInRoleAsync(user, "SuperAdmin"))
                            {
                                @if (await UserManager.IsInRoleAsync(user, "Admin") )
                                {
                                    <form asp-controller="User" asp-action="RemoveAdminRole" method="post" id="myForm">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button class="btn btn-danger" id="submitButton">Do not allow qrcode generation</button>
                                    </form>
                                }
                                else
                                {
                                    if (user.EmailConfirmed)
                                    {
                                        <form asp-controller="User" asp-action="AddAdminRole" method="post">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button class="btn btn-success">Let it generate qrcode</button>
                                        </form>
                                    }                                    
                                }
                            }
                    </td>
                </tr>
                say++;
                }                
            </tbody>
        </table>
        
        </div>
    </div>
