@{
    Layout = null;
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<link rel="stylesheet" href="~/css/style.css">

<!-- Main css -->
<link href="~/fonts/material-icon/css/material-design-iconic-font.css" rel="stylesheet" />

@*<form method="post">*@
